NODE_ENV=production
APP_ORIGIN=https://your-project.vercel.app
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require
JWT_ACCESS_SECRET=replace-with-a-strong-random-secret
JWT_REFRESH_SECRET=replace-with-a-strong-random-secret
COOKIE_SECURE=true
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-rest-token
TURNSTILE_SITE_KEY=replace-with-cloudflare-turnstile-site-key
TURNSTILE_SECRET_KEY=replace-with-cloudflare-turnstile-secret-key
VITE_TURNSTILE_SITE_KEY=replace-with-cloudflare-turnstile-site-key
